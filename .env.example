ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Local dev only: how often the in-process scheduler runs (node-cron syntax).
INGEST_CRON=0 */2 * * *

# Production only (Vercel): point at a Turso database so data survives the
# serverless filesystem. Leave both unset for local dev - a local SQLite file
# under ./data/app.db is used automatically instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Production only (Vercel): set this to a random secret and Vercel Cron will
# send it back as a Bearer token on /api/cron/ingest, so nobody else can
# trigger ingestion. Leave unset locally.
CRON_SECRET=
